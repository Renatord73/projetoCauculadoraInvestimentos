// Contrato
//1 - Sistema deve usar o Tailwindcss
//2 - Sistema deve ter umelemento HTML do tipo table(com o id definido) preparado e sem informações dentro
//3 - São necessários dois arrays para a geração da tabela...
//3.1 - Um array de dados
//3.2 - Um array com objetos que caracterizam as colunas(EX: columnLabel, accessor)
//3.3 - Não é necessário mas pode-se passar uma função de formatação dos dados daquela coluna

type columnObject = {
  columnLabel: String;
  accessor: String;
  formatFN?: (info: number | string) => String;
};

type columnArray = columnObject[];
